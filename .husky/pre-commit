#!/bin/sh

# Jaskier Shared Pattern -- pre-commit hook
# Frontend: lint-staged (biome check + format) + TypeScript check
# Backend: cargo check (only if .rs files staged)

# Ensure node_modules/.bin is in PATH for biome/lint-staged
export PATH="./node_modules/.bin:$PATH"

# Run lint-staged on staged frontend files
# --no-stash: workaround for lint-staged bug where `git stash create` returns
# empty string when there are no unstaged changes, causing `git rev-parse --short ""`
# to fail with "fatal: Needed a single revision" (lint-staged v16.3.2)
npx lint-staged --no-stash
if [ $? -ne 0 ]; then
  echo "lint-staged failed. Fix errors before committing."
  exit 1
fi

# Frontend TypeScript check (only if .ts/.tsx files staged)
if git diff --cached --name-only | grep -q '\.\(ts\|tsx\)$'; then
  npx tsc --noEmit --skipLibCheck
  if [ $? -ne 0 ]; then
    echo "TypeScript check failed. Fix errors before committing."
    exit 1
  fi
fi

