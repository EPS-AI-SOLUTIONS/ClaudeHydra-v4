{
  "name": "claudehydra-v4",
  "private": true,
  "version": "4.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "format": "biome format --write src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:visual": "bun scripts/watchdog-visual.mjs",
    "preview": "vite preview",
    "changelog": "conventional-changelog -p angular -i CHANGELOG.md -s",
    "prepare": "husky",
    "typecheck": "tsc --noEmit",
    "analyze": "vite build --mode analyze"
  },
  "dependencies": {
    "@jaskier/auth": "workspace:*",
    "@jaskier/chat-module": "workspace:*",
    "@jaskier/core": "workspace:*",
    "@jaskier/hydra-app": "workspace:*",
    "@jaskier/i18n": "workspace:*",
    "@jaskier/state": "workspace:*",
    "@jaskier/ui": "workspace:*",
    "@jaskier/vault-client": "workspace:*",
    "@jaskier/wasm-worker": "workspace:*",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-query-devtools": "^5.91.3",
    "@tanstack/react-virtual": "^3.13.23",
    "@xyflow/react": "^12.10.1",
    "dompurify": "^3.3.3",
    "i18next": "^26.0.1",
    "i18next-browser-languagedetector": "^8.2.1",
    "lucide-react": "^1.8.0",
    "motion": "^12.37.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^17.0.1",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "y-websocket": "^2.1.0",
    "yjs": "^13.6.30",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.5.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "conventional-changelog-cli": "^5.0.0",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.4.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "vite-plugin-compression": "^0.5.1"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "bunx biome check --write",
      "bunx biome format --write"
    ],
    "*.css": [
      "bunx biome format --write"
    ]
  },
  "overrides": {
    "undici": ">=7.24.0",
    "serialize-javascript": ">=7.0.3"
  },
  "description": "ClaudeHydra - Part of the Jaskier Workspace Enterprise Ecosystem",
  "author": "Jaskier Workspace"
}
